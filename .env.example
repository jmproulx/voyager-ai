# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/voyager_ai?schema=public"

# ─── Authentication ──────────────────────────────────────────────────────────
# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google OAuth (optional — leave blank to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── AI / Claude API ────────────────────────────────────────────────────────
# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=""

# ─── Travel APIs ─────────────────────────────────────────────────────────────
# Amadeus Self-Service API (developers.amadeus.com)
# Use test environment for development (free, realistic data)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
AMADEUS_BASE_URL="https://test.api.amadeus.com"

# Duffel API (duffel.com) — use test mode access token
DUFFEL_ACCESS_TOKEN=""

# Kiwi.com Tequila API (tequila.kiwi.com) — self-service, no business application needed
# Real live flight data from 750+ carriers
KIWI_API_KEY=""

# ─── Flight Tracking ────────────────────────────────────────────────────────
# FlightAware AeroAPI (flightaware.com/aeroapi)
FLIGHTAWARE_API_KEY=""

# ─── Carbon Footprint ───────────────────────────────────────────────────────
# Climatiq API (climatiq.io)
CLIMATIQ_API_KEY=""

# ─── Calendar Integration ───────────────────────────────────────────────────
# Google Calendar API (console.cloud.google.com)
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""

# ─── Email ───────────────────────────────────────────────────────────────────
# Resend (resend.com) — for transactional emails
RESEND_API_KEY=""

# ─── App Configuration ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
