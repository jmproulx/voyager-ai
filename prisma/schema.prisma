generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  TRAVELER
  MANAGER
  ADMIN
}

enum TripStatus {
  PLANNING
  BOOKED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BookingType {
  FLIGHT
  HOTEL
  CAR_RENTAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHANGED
}

enum BookingProvider {
  AMADEUS
  DUFFEL
  KIWI
}

enum ExpenseCategory {
  FLIGHT
  HOTEL
  MEAL
  TRANSPORT
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageRole {
  USER
  ASSISTANT
  TOOL
}

enum FlightAlertType {
  PRICE_DROP
  DELAY
  CANCELLATION
  GATE_CHANGE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  logo      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  travelPolicy TravelPolicy?
  users        User[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  passwordHash   String?  @map("password_hash")
  image          String?
  role           UserRole @default(TRAVELER)
  organizationId String?  @map("organization_id")
  preferences    Json?    @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization       Organization?     @relation(fields: [organizationId], references: [id])
  trips              Trip[]
  expenses           Expense[]
  conversations      Conversation[]
  approvalRequests   ApprovalRequest[] @relation("RequesterApprovals")
  approvalResponses  ApprovalRequest[] @relation("ApproverApprovals")
  expenseApprovals   Expense[]         @relation("ExpenseApprover")

  accounts Account[]
  sessions Session[]

  @@index([organizationId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Trip {
  id          String     @id @default(cuid())
  name        String
  status      TripStatus @default(PLANNING)
  userId      String     @map("user_id")
  startDate   DateTime?  @map("start_date")
  endDate     DateTime?  @map("end_date")
  destination String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id])
  bookings      Booking[]
  expenses      Expense[]
  itineraryItems ItineraryItem[]
  conversations Conversation[]

  @@index([userId])
  @@index([status])
  @@map("trips")
}

model Booking {
  id                   String         @id @default(cuid())
  type                 BookingType
  tripId               String         @map("trip_id")
  status               BookingStatus  @default(PENDING)
  provider             BookingProvider?
  providerBookingId    String?        @map("provider_booking_id")
  details              Json?
  price                Float
  currency             String         @default("USD")
  policyCompliant      Boolean        @default(true) @map("policy_compliant")
  policyViolationReason String?       @map("policy_violation_reason")
  carbonKg             Float?         @map("carbon_kg")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  trip             Trip              @relation(fields: [tripId], references: [id])
  flightAlerts     FlightAlert[]
  approvalRequests ApprovalRequest[]

  @@index([tripId])
  @@index([status])
  @@map("bookings")
}

model Expense {
  id             String          @id @default(cuid())
  tripId         String?         @map("trip_id")
  userId         String          @map("user_id")
  category       ExpenseCategory
  amount         Float
  currency       String          @default("USD")
  receiptUrl     String?         @map("receipt_url")
  receiptOcrData Json?           @map("receipt_ocr_data")
  status         ExpenseStatus   @default(PENDING)
  merchantName   String?         @map("merchant_name")
  date           DateTime
  description    String?
  approvedById   String?         @map("approved_by_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  trip       Trip?  @relation(fields: [tripId], references: [id])
  user       User   @relation(fields: [userId], references: [id])
  approvedBy User?  @relation("ExpenseApprover", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([tripId])
  @@index([status])
  @@map("expenses")
}

model TravelPolicy {
  id                            String   @id @default(cuid())
  organizationId                String   @unique @map("organization_id")
  rules                         Json     @default("[]")
  maxFlightPrice                Float?   @map("max_flight_price")
  maxHotelPrice                 Float?   @map("max_hotel_price")
  preferredAirlines             String[] @map("preferred_airlines")
  preferredHotelChains          String[] @map("preferred_hotel_chains")
  requireApprovalAbove          Float?   @map("require_approval_above")
  advanceBookingDays            Int?     @map("advance_booking_days")
  allowBusinessClass            Boolean  @default(false) @map("allow_business_class")
  internationalRequiresApproval Boolean  @default(true) @map("international_requires_approval")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("travel_policies")
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tripId    String?  @map("trip_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  trip     Trip?     @relation(fields: [tripId], references: [id])
  messages Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  toolCalls      Json?       @map("tool_calls")
  toolResults    Json?       @map("tool_results")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model FlightAlert {
  id           String          @id @default(cuid())
  bookingId    String          @map("booking_id")
  type         FlightAlertType
  details      Json?
  acknowledged Boolean         @default(false)
  createdAt    DateTime        @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("flight_alerts")
}

model ApprovalRequest {
  id           String         @id @default(cuid())
  bookingId    String         @map("booking_id")
  requesterId  String         @map("requester_id")
  approverId   String         @map("approver_id")
  status       ApprovalStatus @default(PENDING)
  reason       String?
  responseNote String?        @map("response_note")
  createdAt    DateTime       @default(now()) @map("created_at")
  respondedAt  DateTime?      @map("responded_at")

  booking   Booking @relation(fields: [bookingId], references: [id])
  requester User    @relation("RequesterApprovals", fields: [requesterId], references: [id])
  approver  User    @relation("ApproverApprovals", fields: [approverId], references: [id])

  @@index([bookingId])
  @@index([requesterId])
  @@index([approverId])
  @@index([status])
  @@map("approval_requests")
}

model ItineraryItem {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  title       String
  description String?
  startTime   DateTime @map("start_time")
  endTime     DateTime? @map("end_time")
  location    String?
  type        String   @default("event")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tripId])
  @@map("itinerary_items")
}
